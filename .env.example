APP_NAME=TaskFlow API
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true

DATABASE_URL=postgresql+psycopg://taskflow:taskflow_dev_password@localhost:5432/taskflow_dev
TEST_DATABASE_URL=postgresql+psycopg://taskflow_test:taskflow_test_password@localhost:5432/taskflow_test

JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_V1_PREFIX=/api/v1
